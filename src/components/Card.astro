---
interface Props {
  title?: string;
  highlight?: boolean;
  /** Set false for nested/placeholder cards that shouldn't lift on hover */
  interactive?: boolean;
  class?: string;
}

const {
  title,
  highlight = false,
  interactive = true,
  class: cls = "",
} = Astro.props;

const wrap = highlight
  ? "bg-brand border-accent text-header-ink [&_p]:text-header-ink [&_strong]:text-header-ink [&_h4]:text-header-ink"
  : interactive
    ? "bg-surface border-line text-ink-light transition-all duration-200 hover:bg-surface-hover hover:-translate-y-0.5 hover:shadow-md hover:shadow-black/25"
    : "bg-surface border-line text-ink-light";
---

<div
  class:list={[
    "flex h-full flex-col rounded-2xl border p-6 shadow-md shadow-black/20",
    wrap,
    cls,
  ]}
>
  {
    title && (
      <h3
        class:list={[
          "mb-2 text-xl font-semibold",
          highlight ? "text-header-ink" : "text-brand",
        ]}
      >
        {title}
      </h3>
    )
  }
  <slot />
</div>
