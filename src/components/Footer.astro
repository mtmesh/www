---
const social = [
  { href: "https://www.reddit.com/r/mtmesh/", label: "Reddit", icon: "/images/social/reddit-simple.svg" },
  { href: "https://discord.gg/DsReq2nr", label: "Discord", icon: "/images/social/discord-simple.svg" },
  { href: "https://github.com/mtmesh/www", label: "GitHub", icon: "/images/social/github-simple.svg" },
];
const year = new Date().getFullYear();

const footNav = [
  { href: "/learn/", label: "Learn" },
  { href: "/join/", label: "Join" },
  { href: "/devices/", label: "Devices" },
  { href: "/guides/", label: "Guides" },
  { href: "/coverage-map/", label: "Coverage Map" },
  { href: "/partners/", label: "Partners" },
  { href: "/similar-networks/", label: "Similar Networks" },
  { href: "/privacy/", label: "Privacy Policy" },
];

const footLink =
  "text-ink-light no-underline underline-offset-2 transition-colors hover:text-accent hover:underline";
---

<footer class="border-t-2 border-line bg-footer text-ink-muted">
  <div class="mx-auto max-w-6xl px-4 py-12 text-center text-sm">
    <div class="mb-6 flex justify-center gap-2">
      {
        social.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={s.label}
            class="rounded p-2 opacity-80 transition hover:bg-white/5 hover:opacity-100"
          >
            <img src={s.icon} width="22" height="22" alt="" class="brightness-0 invert" />
          </a>
        ))
      }
    </div>

    <nav aria-label="Footer" class="mb-6 flex flex-wrap justify-center gap-x-6 gap-y-2">
      {footNav.map((n) => <a href={n.href} class={footLink}>{n.label}</a>)}
    </nav>

    <p class="mx-auto max-w-2xl text-xs leading-relaxed text-ink-muted">
      This website is a fork of
      <a
        href="https://www.austinmesh.org/"
        target="_blank"
        rel="noopener"
        class={footLink}>Austin Mesh's site</a
      > (which is &copy; by Tommy Ekstrand and is licensed under a Creative
      Commons Attribution-ShareAlike 4.0 International License).
    </p>
    <p class="mt-3 text-xs text-ink-muted">&copy; {year} MTMesh</p>
  </div>
</footer>
