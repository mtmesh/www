---
const nav = [
  { href: "/", label: "Home" },
  { href: "/learn/", label: "Learn" },
  { href: "/join/", label: "Join" },
  { href: "/devices/", label: "Devices" },
  { href: "/guides/", label: "Guides" },
  { href: "/partners/", label: "Partners" },
];

const social = [
  { href: "https://www.reddit.com/r/mtmesh/", label: "Reddit", icon: "/images/social/reddit-simple.svg" },
  { href: "https://discord.gg/DsReq2nr", label: "Discord", icon: "/images/social/discord-simple.svg" },
  { href: "https://github.com/mtmesh/www", label: "GitHub", icon: "/images/social/github-simple.svg" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const linkBase =
  "font-medium text-header-ink no-underline transition hover:opacity-70";
---

<a
  href="#main"
  class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-3 focus:z-[60] focus:rounded focus:bg-base focus:px-3 focus:py-2 focus:text-brand"
>
  Skip to main content
</a>

<header class="sticky top-0 z-50 bg-brand shadow-lg shadow-black/25">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex items-center justify-between gap-4 py-4">
      <a href="/" aria-label="MTMesh home" class="shrink-0">
        <img
          src="/images/MTMesh-Logo.svg"
          alt="MTMesh"
          width="240"
          height="58"
          class="h-11 w-auto transition-transform hover:scale-105 md:h-12"
        />
      </a>

      <!-- Desktop navigation -->
      <nav aria-label="Main navigation" class="hidden items-center gap-6 md:flex">
        <ul class="flex items-center gap-5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    linkBase,
                    isActive(item.href) && "underline underline-offset-8 decoration-2",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="hidden items-center gap-1 lg:flex">
          {
            social.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
                class="rounded p-2 transition hover:bg-black/10"
              >
                <img src={s.icon} width="22" height="22" alt="" />
              </a>
            ))
          }
        </div>
      </nav>

      <!-- Mobile menu (no-JS disclosure) -->
      <details class="group md:hidden">
        <summary
          class="flex cursor-pointer list-none items-center rounded p-2 text-header-ink [&::-webkit-details-marker]:hidden"
          aria-label="Toggle menu"
        >
          <svg class="h-7 w-7 group-open:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="hidden h-7 w-7 group-open:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </summary>
        <div class="menu-panel absolute inset-x-0 top-full bg-brand px-4 pb-5 shadow-lg shadow-black/25">
          <ul class="flex flex-col gap-1 border-t border-header-ink/15 pt-3">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? "page" : undefined}
                    class:list={[
                      "block rounded-md px-3 py-2.5 text-header-ink no-underline transition hover:bg-black/10",
                      isActive(item.href) && "font-semibold",
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <div class="mt-3 flex gap-1 border-t border-header-ink/15 pt-3">
            {
              social.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={s.label}
                  class="rounded p-2 transition hover:bg-black/10"
                >
                  <img src={s.icon} width="22" height="22" alt="" />
                </a>
              ))
            }
          </div>
        </div>
      </details>
    </div>
  </div>
</header>
