---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";

const stemPoints = [
  {
    title: "Wireless Communication",
    body: "Students learn fundamentals of wireless technology and how radio waves enable long-range communication.",
  },
  {
    title: "Electronics & Coding",
    body: "Hands-on experience building mesh networks, programming devices, and troubleshooting systems.",
  },
  {
    title: "Problem Solving",
    body: "Critical thinking and collaboration through real-world challenges in network design and deployment.",
  },
  {
    title: "Career Exploration",
    body: "Explore careers in technology, communication, software development, and emergency services.",
  },
];

const benefitPoints = [
  {
    title: "Enhanced Communication",
    body: "Provide backup communications during emergencies or network outages. Keep your community connected when it matters most.",
  },
  {
    title: "Community Resilience",
    body: "Support local emergency preparedness and disaster response capabilities. Help build a more resilient Montana.",
  },
  {
    title: "Technical Innovation",
    body: "Participate in cutting-edge mesh networking technology and be part of the communication revolution.",
  },
  {
    title: "Educational Impact",
    body: "Support STEM education in Montana communities and help prepare students for technology careers.",
  },
];
---

<Base
  title="Partners"
  fullTitle="Community Partners | MTMesh"
  description="Learn how to partner with MTMesh to expand Meshtastic networks across Montana, or reach out to become a partner."
>
  <!-- Hero Section -->
  <Section>
    <div class="text-center">
      <h1 class="mb-12 text-center">Partner with MTMesh</h1>
      <p class="text-lg mb-8">
        Join us in building Montana's most resilient communication network.
        Together, we can strengthen communities across Big Sky Country.
      </p>
      <Button
        href="https://discord.gg/DsReq2nr"
        target="_blank" rel="noopener"
        variant="secondary"
        size="lg"
      >
        Join Our Community
      </Button>
    </div>
  </Section>

  <!-- Partnership Types -->
  <Section>
    <h2 class="mb-12 text-center">Partnership Opportunities</h2>

    <div class="grid gap-8 sm:grid-cols-2 mb-8">
      <Card title="Educational Partnerships">
        <p class="mb-4">
          Partner with Montana schools, universities, and educational
          organizations to bring hands-on STEM learning to students across the
          state.
        </p>
        <p>
          <strong>Perfect for:</strong> K-12 Schools, Universities, Libraries,
          Community Centers, Amateur Radio Clubs
        </p>
        <div class="mt-6">
          <Button href="https://www.reddit.com/r/mtmesh/" target="_blank" rel="noopener"
            >Connect on Reddit</Button
          >
        </div>
      </Card>

      <Card title="Community & Business">
        <p class="mb-4">
          Join Montana businesses, municipalities, and community organizations
          in expanding mesh network coverage across the state.
        </p>
        <p>
          <strong>Perfect for:</strong> Local Businesses, Municipalities, Emergency
          Services, Rural Communities
        </p>
        <div class="mt-6">
          <Button href="https://discord.gg/DsReq2nr" target="_blank" rel="noopener"
            >Join Discussion</Button
          >
        </div>
      </Card>
    </div>
  </Section>

  <!-- STEM Education Deep Dive -->
  <Section surface>
    <div class="text-center mb-8">
      <h2 class="mb-4 text-center">STEM Learning with Meshtastic Technology</h2>
      <p class="text-lg">
        Empowering Montana's next generation through hands-on wireless
        communication education
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        stemPoints.map((p) => (
          <Card title={p.title}>
            <p>{p.body}</p>
          </Card>
        ))
      }
    </div>
  </Section>

  <!-- Partnership Benefits -->
  <Section>
    <div class="text-center mb-8">
      <h2 class="mb-4 text-center">Why Partner with MTMesh?</h2>
      <p class="text-lg">
        Discover the benefits of joining Montana's mesh networking community
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      {
        benefitPoints.map((p) => (
          <Card title={p.title}>
            <p>{p.body}</p>
          </Card>
        ))
      }
    </div>
  </Section>

  <!-- How to Partner -->
  <Section surface>
    <div class="text-center mb-8">
      <h2 class="mb-4 text-center">How You Can Partner</h2>
      <p class="text-lg">
        Multiple ways to get involved and strengthen Montana's mesh network
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <Card title="Host a Node">
        <p class="mb-4">
          Provide rooftop or tower space for mesh network repeaters. Help
          extend coverage across Montana's vast landscape.
        </p>
        <ul class="mb-6 list-disc pl-5 text-ink-muted">
          <li>Solar-powered, low maintenance</li>
          <li>Minimal space requirements</li>
          <li>Community impact visibility</li>
        </ul>
        <Button href="/join/" variant="outline">Learn About Hosting</Button>
      </Card>

      <Card title="Sponsor Equipment">
        <p class="mb-4">
          Support network expansion through equipment donations or funding.
          Every device strengthens the network.
        </p>
        <ul class="mb-6 list-disc pl-5 text-ink-muted">
          <li>Tax-deductible donations</li>
          <li>Recognition opportunities</li>
          <li>Direct community benefit</li>
        </ul>
        <Button href="https://www.reddit.com/r/mtmesh/" target="_blank" rel="noopener" variant="outline"
          >Connect on Reddit</Button
        >
      </Card>

      <Card title="Educational Support">
        <p class="mb-4">
          Host workshops, provide expertise, or offer facilities for community
          programs and student learning.
        </p>
        <ul class="mb-6 list-disc pl-5 text-ink-muted">
          <li>Workshop hosting</li>
          <li>Expert mentorship</li>
          <li>Facility sharing</li>
        </ul>
        <Button href="https://discord.gg/DsReq2nr" target="_blank" rel="noopener" variant="outline"
          >Join Community</Button
        >
      </Card>

      <Card title="Emergency Services">
        <p class="mb-4">
          Integrate mesh communications into emergency response plans and
          disaster preparedness strategies.
        </p>
        <ul class="mb-6 list-disc pl-5 text-ink-muted">
          <li>Backup communications</li>
          <li>Disaster resilience</li>
          <li>Interoperability training</li>
        </ul>
        <Button href="https://www.reddit.com/r/mtmesh/" target="_blank" rel="noopener" variant="outline"
          >Discuss on Reddit</Button
        >
      </Card>
    </div>
  </Section>

  <!-- Call to Action -->
  <Section>
    <div class="text-center">
      <h2 class="mb-4 text-center">Ready to Make an Impact?</h2>
      <p class="text-lg mb-8">
        Let's work together to strengthen Montana communities through
        innovative mesh networking technology.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="https://discord.gg/DsReq2nr" target="_blank" rel="noopener" variant="secondary" size="lg"
          >Join Our Community</Button
        >
        <Button href="/learn/" variant="outline" size="lg"
          >Learn About Mesh Networks</Button
        >
      </div>
    </div>
  </Section>
</Base>
